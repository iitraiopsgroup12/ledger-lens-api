LEDGER_LENS_SYNC_URL=http://localhost:8000/
LEDGER_LENS_RAG_URL=http://localhost:8080/
BACKEND_REQUEST_TIMEOUT_SECONDS=1800

# JWT signing — MUST be overridden with a strong random secret in every
# non-local environment (e.g. `openssl rand -hex 32`).
JWT_SECRET=dev-only-insecure-change-me-0123456789abcdef
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
